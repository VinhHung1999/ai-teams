generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://hungphu@localhost:5432/ai_teams"
}

model Project {
  id                Int           @id @default(autoincrement())
  name              String
  tmux_session_name String?
  working_directory String?
  created_at        DateTime      @default(now())
  backlog_items     BacklogItem[]
  sprints           Sprint[]

  @@map("projects")
}

model BacklogItem {
  id                  Int          @id @default(autoincrement())
  project_id          Int
  project             Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  title               String
  description         String?
  priority            String       @default("P2")
  story_points        Int?
  acceptance_criteria Json?
  status              String       @default("new")
  order               Int          @default(0)
  created_at          DateTime     @default(now())
  updated_at          DateTime     @default(now()) @updatedAt
  sprint_items        SprintItem[]

  @@index([project_id])
  @@map("backlog_items")
}

model Sprint {
  id           Int          @id @default(autoincrement())
  project_id   Int
  project      Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  number       Int
  goal         String?
  status       String       @default("planning")
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime     @default(now())
  items        SprintItem[]

  @@index([project_id])
  @@map("sprints")
}

model SprintItem {
  id              Int         @id @default(autoincrement())
  sprint_id       Int
  sprint          Sprint      @relation(fields: [sprint_id], references: [id], onDelete: Cascade)
  backlog_item_id Int
  backlog_item    BacklogItem @relation(fields: [backlog_item_id], references: [id], onDelete: Cascade)
  assignee_role   String?
  board_status    String      @default("todo")
  order           Int         @default(0)
  notes           String?
  updated_at      DateTime    @default(now()) @updatedAt

  @@index([sprint_id])
  @@index([backlog_item_id])
  @@map("sprint_items")
}

model Notification {
  id           Int      @id @default(autoincrement())
  project_id   Int
  session_name String
  from_role    String?
  message      String
  urgency      String   @default("normal")
  read         Boolean  @default(false)
  created_at   DateTime @default(now())

  @@index([project_id])
  @@map("notifications")
}
